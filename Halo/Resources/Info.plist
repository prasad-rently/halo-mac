<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Halo</string>
    <key>CFBundleDisplayName</key>
    <string>Halo</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Prasad. Released under the MIT License.</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <!-- Apple Events / Automation — required for NSAppleScript to control other apps -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Halo uses Finder to safely empty your Trash and perform system maintenance tasks.</string>
    <!-- Voice search in Quick Actions -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Halo uses the microphone for optional voice-to-text search in the Quick Actions panel.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Halo uses speech recognition so you can say a task name (e.g. "clear xcode cache") and have matching Quick Actions suggested automatically.</string>
    <!-- Required usage descriptions -->
    <key>NSDesktopFolderUsageDescription</key>
    <string>Halo scans your Desktop for large and duplicate files.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>Halo scans your Documents folder for large and duplicate files.</string>
    <key>NSDownloadsFolderUsageDescription</key>
    <string>Halo scans your Downloads folder for files that can be cleaned up.</string>
    <!-- Background modes -->
    <key>NSBackgroundModes</key>
    <array>
        <string>fetch</string>
    </array>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.halo.smartscan</string>
    </array>
    <!-- HaloShare: local network file transfer -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Halo uses the local network to discover and transfer files with nearby devices running Halo or LocalSend.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_localsend._tcp</string>
    </array>
    <!-- F-006: Sentry crash reporting — replace placeholder with real DSN before release -->
    <key>SentryDSN</key>
    <string>SENTRY_DSN_PLACEHOLDER</string>
    <key>SentryEnabled</key>
    <true/>
</dict>
</plist>
